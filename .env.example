# ════════════════════════════════════════════════════════════════
# Server environment variables for local development
#
# SETUP:
#   1. Copy this file to .env.server:
#        cp .env.example .env.server
#   2. Fill in YOUR credentials below
#   3. Run: yarn dev
#
# NOTE: .env.server is .gitignored — never commit real credentials
# NOTE: Do NOT include /v1 suffix in TDP_ENDPOINT
# ════════════════════════════════════════════════════════════════

PORT=3000
TDP_ENDPOINT=https://api.takeda-pillar-dev.tetrascience.com/v1
ORG_SLUG=takeda-gxp-dev

# Extract from cookies in your browser:
# 1. Open TDP in your browser and log in
# 2. Open Developer Tools > Application > Cookies
# 3. Find the 'ts_auth_token' cookie and copy its value here
TS_AUTH_TOKEN=your-auth-token-here

# ════════════════════════════════════════════════════════════════
# AWS / Athena SQL access
# These are ONLY needed for LOCAL development.
# In production (TDP), these come from the Data App Provider.
# ════════════════════════════════════════════════════════════════
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Athena workgroup + default database used for queries
ATHENA_WORKGROUP=takeda-gxp-dev
ATHENA_DATABASE=takeda_gxp_dev__tss__external

# Where Athena writes results
ATHENA_S3_OUTPUT_LOCATION=s3://takeda-dev-prod-athena-results/takeda_gxp_dev/
